{% comment %}
  Notes navigation ("Contents") — category tree of all notes grouped by method type.
  Reusable on the /blog/ index and in each note's left sidebar.
{% endcomment %}
<style>
  nav.notes-contents .list-unstyled li { margin-bottom: 0.2rem; line-height: 1.3; }
  nav.notes-contents p.mb-1 { margin-bottom: 0.1rem; margin-top: 0.4rem; }
  nav.notes-contents a[data-toggle="collapse"] .fa-caret-down { transition: transform 0.2s ease; }
  nav.notes-contents a[data-toggle="collapse"].collapsed .fa-caret-down { transform: rotate(-90deg); }
  nav.notes-contents .ct-type { display:inline-block; padding:0.02rem 0.5rem; border-radius:999px; font-size:0.66rem; font-weight:700; letter-spacing:0.02em; }
  nav.notes-contents a { color:#1c1c1d; }
  nav.notes-contents a:hover { color:#6e85b7; }
  nav.notes-contents a.cat-chip { color:#1c1c1d; background-color:rgba(0,0,0,0.05); }
  nav.notes-contents a.cat-chip { display: inline-block; padding: 0.05rem 0.5rem; border-radius: 999px; font-weight: 600; line-height: 1.4; text-decoration: none; }
  nav.notes-contents a.cat-chip:hover { background-color: rgba(110,133,183,0.22); }
  nav.notes-contents .gen-tag { font-size:0.56rem; font-weight:700; color:#7e9bbf; letter-spacing:0.02em; vertical-align:1px; }
</style>

<nav class="sticky-top notes-contents" style="top:5rem;font-size:0.78rem;">
  <h6 class="mb-2" style="font-weight:700;color:#1c1c1d">Contents</h6>
  {% for cat_slug in site.display_categories %}
    {% assign cat_posts = site.categories[cat_slug] %}
    {% unless cat_posts %}{% continue %}{% endunless %}
    {% assign survey_count = cat_posts | where_exp: "p", "p.tags contains 'survey'" | size %}
    {% assign paper_count = cat_posts | size | minus: survey_count %}
    {% assign cat_fallback = cat_slug | replace: '-', ' ' | capitalize %}
    {% assign cat_name = site.data.note_categories[cat_slug].name | default: cat_fallback %}
    <p class="mb-1 mt-2">
      <a data-toggle="collapse" href="#contents-{{ forloop.index }}" role="button" aria-expanded="false" class="d-block text-decoration-none collapsed" style="font-weight:700;color:#1c1c1d">
        <i class="fa-solid fa-caret-down fa-xs mr-1"></i>{{ cat_name }} <span style="font-weight:600;color:#1c1c1d">({{ paper_count }})</span>
      </a>
    </p>
    <div class="collapse" id="contents-{{ forloop.index }}">
      <ul class="list-unstyled mb-3" style="padding-left:0.9rem;font-size:0.72rem">
        {% comment %} survey/overview 먼저 고정 {% endcomment %}
        {% for post in cat_posts %}{% if post.tags contains 'survey' %}
          <li class="mb-2"><a href="{{ post.url | relative_url }}">{{ post.shortname | default: post.title }}</a></li>
        {% endif %}{% endfor %}
        {% comment %} 방법 계열별 그룹 (그룹 내 연도순) {% endcomment %}
        {% if cat_slug == 'efficient-vlm' %}
          {% assign type_order = "encoder-side,bridge,llm-side,encoder-llm" | split: "," %}
        {% else %}
          {% assign type_order = "pruning,merging,pooling,hybrid,vlm,modality-encoder,input-projector,llm-backbone,output-projector,modality-generator" | split: "," %}
        {% endif %}
        {% for t in type_order %}
          {% assign group = cat_posts | where_exp: "p", "p.tags contains t" | sort: "date" %}
          {% if group.size > 0 %}
            {% assign tc = site.data.note_tags[t] %}
            {% if tc.name %}{% assign tname = tc.name %}{% else %}{% assign tname = t | capitalize %}{% endif %}
            <li class="mt-2 mb-1"><span class="ct-type" style="background-color:{{ tc.bg }};color:{{ tc.fg }}">{{ tname }}</span></li>
            {% for post in group %}
            <li class="mb-1" style="padding-left:0.25rem"><a href="{{ post.url | relative_url }}">{{ post.shortname | default: post.title }}</a>{% if post.generation %} <span class="gen-tag">{{ post.generation }}</span>{% endif %}{% if post.venue %} <span class="text-muted" style="font-size:0.66rem">{{ post.venue }}</span>{% endif %}</li>
            {% endfor %}
          {% endif %}
        {% endfor %}
      </ul>
    </div>
  {% endfor %}
  {% if site.display_categories and site.display_categories.size > 0 %}
  <div class="mt-3" style="font-size:0.72rem">
    <h6 class="mb-2" style="font-weight:700;color:#1c1c1d">Categories</h6>
    {% for category in site.display_categories %}
      {% assign cat_fallback = category | replace: '-', ' ' | capitalize %}
      {% assign cat_name = site.data.note_categories[category].name | default: cat_fallback %}
      <a class="cat-chip d-inline-block mb-1" href="{{ category | slugify | prepend: '/blog/category/' | relative_url }}"><i class="fa-solid fa-tag fa-sm"></i> {{ cat_name }}</a>
    {% endfor %}
  </div>
  {% endif %}
</nav>
