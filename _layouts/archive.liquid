---
layout: default
---

<style>
  .post .post-list li { margin-bottom: 0.55rem; padding-top: 1rem; padding-bottom: 0; border-bottom: none; }
  .post .post-list .post-title { text-transform: none; font-weight: 700; letter-spacing: -0.005em; }
  .post .post-list h3 + p { font-size: 0.86rem; line-height: 1.5; margin-bottom: 0.35rem; }
  .post .post-list .post-meta { font-size: 0.74rem; margin-bottom: 0.2rem; }
  .post .post-list .post-tags { font-size: 0.74rem; margin-bottom: 0; }
  .post .post-list .tag-chip { display:inline-block; padding:0.05rem 0.5rem; border-radius:999px; font-weight:600; line-height:1.4; text-decoration:none; }
  .post .post-list .tag-chip:hover { filter: brightness(0.94); }
  .post .post-list .card-img { width:100%; height:90px; object-fit:contain; background-color:#f5f5f7; border-radius:6px; }
  nav.sticky-top .list-unstyled li { margin-bottom: 0.2rem; line-height: 1.3; }
  nav.sticky-top .ct-type { display:inline-block; padding:0.02rem 0.5rem; border-radius:999px; font-size:0.66rem; font-weight:700; letter-spacing:0.02em; }
  nav.sticky-top a { color:#1c1c1d; }
  nav.sticky-top a:hover { color:#5d5c98; }
  .post .archive-header .post-title { text-transform:none; font-weight:800; }
</style>

<div class="post">
  {% assign doc_count = page.documents | size %}
  {% if page.type == 'categories' %}
    {% assign cat_fallback = page.title | replace: '-', ' ' | capitalize %}
    {% assign cat_name = site.data.note_categories[page.title].name | default: cat_fallback %}
  {% endif %}

  <div class="row">
  {% if page.type == 'categories' %}
    {% comment %} 이 카테고리만의 Contents 사이드바 {% endcomment %}
    <div class="col-lg-3 mb-4 order-2 order-lg-1">
      <nav class="sticky-top" style="top:5rem;font-size:0.78rem;">
        <h6 class="mb-2" style="font-weight:700;color:#1c1c1d">Contents</h6>
        <p class="mb-1" style="font-weight:700;color:#1c1c1d"><a href="{{ page.url | relative_url }}" class="text-decoration-none" style="color:#1c1c1d">{{ cat_name }}</a></p>
        <ul class="list-unstyled mb-3" style="padding-left:0.9rem;font-size:0.72rem">
          {% for post in page.documents %}{% if post.tags contains 'survey' %}
            <li class="mb-2"><a href="{{ post.url | relative_url }}">{{ post.shortname | default: post.title }}</a></li>
          {% endif %}{% endfor %}
          {% assign type_order = "pruning,merging,pooling,hybrid" | split: "," %}
          {% for t in type_order %}
            {% assign group = page.documents | where_exp: "p", "p.tags contains t" | sort: "date" %}
            {% if group.size > 0 %}
              {% assign tc = site.data.note_tags[t] %}
              <li class="mt-2 mb-1"><span class="ct-type" style="background-color:{{ tc.bg }};color:{{ tc.fg }}">{{ t | capitalize }}</span></li>
              {% for post in group %}
              <li class="mb-1" style="padding-left:0.25rem"><a href="{{ post.url | relative_url }}">{{ post.shortname | default: post.title }}</a>{% if post.venue %} <span class="text-muted" style="font-size:0.66rem">{{ post.venue }}</span>{% endif %}</li>
              {% endfor %}
            {% endif %}
          {% endfor %}
        </ul>
      </nav>
    </div>
    <div class="col-lg-9 order-1 order-lg-2">
  {% else %}
    <div class="col-12">
  {% endif %}

    <header class="post-header archive-header mb-2">
      {% if page.type == 'categories' %}
        <h1 class="post-title">{{ cat_name }}</h1>
        <p class="post-description">{{ doc_count }} note{% if doc_count != 1 %}s{% endif %} in this category</p>
      {% elsif page.type == 'year' %}
        <h1 class="post-title"><i class="fa-solid fa-calendar fa-sm"></i> {{ page.date | date: '%Y' }}</h1>
        <p class="post-description">{{ doc_count }} note{% if doc_count != 1 %}s{% endif %} from {{ page.date | date: '%Y' }}</p>
      {% elsif page.type == 'tags' %}
        <h1 class="post-title"><i class="fa-solid fa-hashtag fa-sm"></i> {{ page.title }}</h1>
        <p class="post-description">{{ doc_count }} note{% if doc_count != 1 %}s{% endif %} tagged &ldquo;{{ page.title }}&rdquo;</p>
      {% endif %}
    </header>

    <ul class="post-list">
      {% assign docs = page.documents | sort: 'date' | reverse %}
      {% for post in docs %}
        {% if post.redirect == blank %}{% assign doc_url = post.url | relative_url %}
        {% elsif post.redirect contains '://' %}{% assign doc_url = post.redirect %}
        {% else %}{% assign doc_url = post.redirect | relative_url %}{% endif %}
        {% assign year = post.date | date: "%Y" %}
        <li>
          {% if post.thumbnail %}<div class="row"><div class="col-sm-9">{% endif %}
            <h3><a class="post-title" href="{{ doc_url }}">{{ post.title }}</a></h3>
            <p>{{ post.description }}</p>
            <p class="post-meta">{% if post.venue %}{{ post.venue }}{% else %}{{ post.date | date: '%B %d, %Y' }}{% endif %}</p>
            <p class="post-tags">
              <i class="fa-solid fa-calendar fa-sm"></i> {{ year }}
              {% if post.tags.size > 0 %}&nbsp; &middot; &nbsp;
              {% for tag in post.tags %}{% assign tc = site.data.note_tags[tag] %}{% if tc %}<a class="tag-chip" href="{{ tag | slugify | prepend: '/blog/tag/' | relative_url }}" style="background-color:{{ tc.bg }};color:{{ tc.fg }}"><i class="fa-solid fa-hashtag fa-sm"></i> {{ tag }}</a>{% else %}<a href="{{ tag | slugify | prepend: '/blog/tag/' | relative_url }}"><i class="fa-solid fa-hashtag fa-sm"></i> {{ tag }}</a>{% endif %}{% unless forloop.last %} {% endunless %}{% endfor %}
              {% endif %}
            </p>
          {% if post.thumbnail %}</div><div class="col-sm-3"><a href="{{ doc_url }}"><img class="card-img" src="{{ post.thumbnail | relative_url }}" alt=""></a></div></div>{% endif %}
        </li>
      {% endfor %}
    </ul>

    </div>
  </div>
</div>
