---
layout: default
---
<div class="post">
  <header class="post-header">
    {% assign doc_count = page.documents | size %}
    {% if page.type == 'categories' %}
      {% assign cat_fallback = page.title | replace: '-', ' ' | capitalize %}
      {% assign cat_name = site.data.note_categories[page.title].name | default: cat_fallback %}
      <h1 class="post-title"><i class="fa-solid fa-tag fa-sm"></i> {{ cat_name }}</h1>
      <p class="post-description">{{ doc_count }} note{% if doc_count != 1 %}s{% endif %} in this category</p>
    {% elsif page.type == 'year' %}
      <h1 class="post-title"><i class="fa-solid fa-calendar fa-sm"></i> {{ page.date | date: '%Y' }}</h1>
      <p class="post-description">{{ doc_count }} note{% if doc_count != 1 %}s{% endif %} from {{ page.date | date: '%Y' }}</p>
    {% elsif page.type == 'tags' %}
      <h1 class="post-title"><i class="fa-solid fa-hashtag fa-sm"></i> {{ page.title }}</h1>
      <p class="post-description">{{ doc_count }} note{% if doc_count != 1 %}s{% endif %} tagged &ldquo;{{ page.title }}&rdquo;</p>
    {% endif %}
  </header>

  <article class="archive">
    {% assign docs = page.documents | sort: 'date' %}
    <ul class="archive-list list-unstyled">
      {% for document in docs %}
        {% if document.redirect == blank %}
          {% assign doc_url = document.url | relative_url %}
          {% assign doc_target = '' %}
        {% elsif document.redirect contains '://' %}
          {% assign doc_url = document.redirect %}
          {% assign doc_target = '_blank' %}
        {% else %}
          {% assign doc_url = document.redirect | relative_url %}
          {% assign doc_target = '' %}
        {% endif %}
        <li class="d-flex align-items-center py-2" style="border-bottom:1px solid var(--global-divider-color);">
          {% if document.thumbnail %}
            <a href="{{ doc_url }}" {% if doc_target != '' %}target="{{ doc_target }}"{% endif %} class="flex-shrink-0 mr-3">
              <img src="{{ document.thumbnail | relative_url }}" style="width:92px;height:58px;object-fit:cover;border-radius:6px;" alt="" loading="lazy">
            </a>
          {% endif %}
          <div class="flex-grow-1">
            <a class="post-link" href="{{ doc_url }}" {% if doc_target != '' %}target="{{ doc_target }}"{% endif %}>{{ document.title }}</a>
            {% if document.venue %}
              <span class="badge rounded-pill ml-2" style="background-color:#4d5f8c;color:#fff;font-size:0.7rem;vertical-align:middle;">{{ document.venue }}</span>
            {% endif %}
          </div>
        </li>
      {% endfor %}
    </ul>
  </article>
</div>
